{
  "name": "student-certificate-sbt",
  "version": "1.0.0",
  "description": "Soulbound Token (SBT) for Academic Certificate Authentication on Ethereum",
  "author": "",
  "license": "MIT",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
